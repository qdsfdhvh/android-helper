{
  "devDependencies" : {
    "@tailwindcss\/vite" : "^4.3.0",
    "tailwindcss" : "^4.3.0",
    "vite" : "^7.3.5"
  },
  "muxy" : {
    "$schema" : "https:\/\/raw.githubusercontent.com\/muxy-app\/muxy\/main\/docs\/extensions\/schema\/manifest.schema.json",
    "description" : "Android devices panel: list, install, file browser, logcat — all from the sidebar",
    "commands" : [
      {
        "action" : {
          "kind" : "togglePanel",
          "panel" : "devices"
        },
        "defaultShortcut" : "cmd+shift+a",
        "id" : "toggle-devices",
        "title" : "Android: Toggle Devices Panel"
      },
      {
        "id" : "refresh-devices",
        "title" : "Android: Refresh Devices"
      }
    ],
    "panels" : [
      {
        "entry" : "panel\/index.html",
        "headerButtons" : [
          {
            "command" : "refresh-devices",
            "icon" : {
              "symbol" : "arrow.clockwise"
            },
            "id" : "refresh",
            "tooltip" : "Refresh devices"
          }
        ],
        "icon" : {
          "symbol" : "iphone"
        },
        "id" : "devices",
        "mode" : "pinned",
        "position" : "right",
        "title" : "Android Devices"
      }
    ],
    "permissions" : [
      "panels:write",
      "commands:exec",
      "tabs:write"
    ],
    "topbarItems" : [
      {
        "command" : "toggle-devices",
        "icon" : {
          "symbol" : "iphone"
        },
        "id" : "devices",
        "tooltip" : "Toggle Android Devices panel"
      }
    ]
  },
  "name" : "android-helper",
  "private" : true,
  "scripts" : {
    "build" : "vite build",
    "dev" : "vite",
    "update-skill" : "node -e \"const fs=require('fs'),p=require('path');const url='https:\/\/raw.githubusercontent.com\/muxy-app\/muxy\/main\/Muxy\/Resources\/skills\/muxy-extension\/SKILL.md';fetch(url).then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.text()}).then(t=>{for(const d of ['.claude\/skills\/muxy-extension','.agents\/skills\/muxy-extension']){fs.mkdirSync(d,{recursive:true});fs.writeFileSync(p.join(d,'SKILL.md'),t);console.log('Updated '+p.join(d,'SKILL.md'))}}).catch(e=>{console.error('Failed to update skill:',e.message);process.exit(1)})\""
  },
  "type" : "module",
  "version" : "0.0.1"
}